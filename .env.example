# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
HOST=0.0.0.0
NODE_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed for the API
CORS_ORIGINS=http://localhost:3000

# ── Limits ────────────────────────────────────────────────────────────────────
# Max payload size in bytes for encrypted items (default 100 KB)
MAX_PAYLOAD_SIZE_BYTES=102400

# ── Playground ────────────────────────────────────────────────────────────────
PLAYGROUND_TOKEN_SECRET=change-me-playground-secret-at-least-32-chars-long
PLAYGROUND_SESSION_TTL_SECONDS=900
PLAYGROUND_MAX_PAYLOAD_SIZE_BYTES=20480
PLAYGROUND_MAX_TTL_SECONDS=86400
PLAYGROUND_MAX_VIEWS=3
PLAYGROUND_CREATE_DAILY_LIMIT=20
PLAYGROUND_READ_DAILY_LIMIT=40
