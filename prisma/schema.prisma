// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  enterprise
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  emailVerifiedAt  DateTime?
  emailVerifyHash  String?
  emailVerifyUntil DateTime?
  plan             Plan           @default(free)
  twoFactorEnabled Boolean        @default(false)
  twoFactorSecret  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt


  emailEvents  EmailEvent[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// Tracks which onboarding emails have been sent to each user.
// Used by the email job to avoid duplicate sends.
model EmailEvent {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'welcome' | 'day2_nudge' | 'day7_api' | 'day14_upgrade'
  sentAt    DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("email_events")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  prefix     String
  keyHash    String    @unique
  userId     String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // "create" | "read" | "delete"
  itemId    String?  // Redis key ID (nullable — deleted items have no DB record)
  userId    String
  meta      Json?    // e.g. { ip, userAgent, apiKeyId }
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("audit_logs")
}
