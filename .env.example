# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fadekey?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-at-least-64-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-64-chars-long

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed for private endpoints (auth, dashboard, keys)
CORS_ORIGINS=http://localhost:3000

# ── Email (Resend API) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="FadeKey <noreply@fadekey.app>"

# ── App ───────────────────────────────────────────────────────────────────────
# Used in email links — must match your frontend URL
APP_URL=http://localhost:3000

# ── Limits ────────────────────────────────────────────────────────────────────
# Max payload size in bytes for encrypted items (default 100 KB)
MAX_PAYLOAD_SIZE_BYTES=102400

# Playground mode is for the interactive documentation inside production.
# It bypasses monthly account quota only when the docs issue a short-lived token.
PLAYGROUND_TOKEN_SECRET=change-me-playground-secret-at-least-32-chars-long
PLAYGROUND_SESSION_TTL_SECONDS=900
PLAYGROUND_MAX_PAYLOAD_SIZE_BYTES=20480
PLAYGROUND_MAX_TTL_SECONDS=86400
PLAYGROUND_MAX_VIEWS=3
PLAYGROUND_CREATE_DAILY_LIMIT=20
PLAYGROUND_READ_DAILY_LIMIT=40

# ── Contact form ──────────────────────────────────────────────────────────────
# Destination address for contact form submissions — never hard-coded in source
CONTACT_EMAIL=your@email.com
