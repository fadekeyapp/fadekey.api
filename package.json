{
  "name": "fadekey-api",
  "version": "0.2.8",
  "description": "Stateless, Redis-backed zero-knowledge sharing engine for FadeKey",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "sdk:install": "npm --prefix sdk install",
    "sdk:build": "npm --prefix sdk run build",
    "sdk:typecheck": "npm --prefix sdk run typecheck",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "publish": "node scripts/publish.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
