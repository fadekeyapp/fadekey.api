    "ioredis": "^5.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
